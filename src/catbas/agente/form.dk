#include "dkli.dkh"
#set "meta-xml-declaration" ""

#!

module "form_agente.dk"
{
    #include "functions.dkh"
    #include "serialize.dkh"
    #include "dbr.dkh"
    #include "uielements.dkl"
    #include "../config.dk"
    #include "../_lib/icons.dk"

    // do rise_error(99,to.json(@crud_context))
    do @context.begin(@crud_context)
    entity_id = @("$parameters/_entity_id")
    isNew = (entity_id == "_new")
    @url_root_entity = @LIST_AGENTES

    new def_pais
    {
        @"datatable*":dbr.list(@("&database"),"select sys_pk, codigotel, nombre from pais order by nombre;",@null)
        member "attributes"
        {
            @"class":"induxsoft-form-select pais"
            @"style":"!important;border-color:#357aff"
        }
        @"value_field":"sys_pk"
        @"text_field":"nombre"
    }

	
    #$ div(class="container p-0")
	{
        #! #include "agente.dk"

        #$ form(action="." method="POST")
        {
            div(id="main_bar" class="row container-section my-2 px-0 py-2 border-bottom")
            {
                div(class="col-4 d-flex align-items-center p-0")
                {
                    h5(class="tex-no-break m-0"){$"#<ifstr(isNew,'Agregar','Editar')> Agente"}
                }
                div(class="col-8 d-flex align-items-center justify-content-end p-0 gap-2" id="main_bar_controls")
                {
                    a(href="./" class="btn btn-sm border-secondary induxsoft-corners btn-main-action" title="Refrescar"){$"#<@ICON_ARROW_CLOCKWISE>"}
                    button(type="button" onclick="validate()" class="btn btn-sm border-secondary induxsoft-corners btn-main-action"){$"#<@ICON_SAVE>"}
                    a(href="../" class="btn btn-sm border-secondary induxsoft-corners btn-main-action"){$"#<@ICON_X_LG>"}
                }
            }
            div(id="work_area" class="container-section")
            {
                div(class="#<ifstr(@('error/message')!='','alert alert-danger','')>"){$"#<@('error/message')>"}
                div(class="mb-3 row")       
                {
                    div(class="col-sm-6")
                    {
                        small(class="fw-bold"){"Código:"}
                        input(type="text" id="codigo" name="codigo" class="induxsoft-form-control" value="#<@('./codigo')>" maxlength="10" placeholder="<A>")
                    }
                    div(class="col-sm-6")
                    {
                        small(class="fw-bold"){"Nombre:"}
                        input(type="text" id="nombre" name="nombre" class="induxsoft-form-control" value="#<@('./nombre')>" maxlength="50")
                    }
                    div(class="col-sm-6")
                    {
                        small(class="fw-bold"){"Comisión(%):"}
                        input(type="number" id="pcomision" name="pcomision" step="any" class="induxsoft-form-control" value="#<@('./pcomision')>")
                    }
                    div(class="col-sm-6")
                    {
                        small{"Código de Nomina:"}
                        input(type="text" id="codnomina" name="codnomina" class="induxsoft-form-control" value="#<@('./codnomina')>" maxlength="50")
                    }
                    div(class="col-sm-6")
                    {
                        small{"Télefono:"}
                        input(type="text" id="telefono1" name="telefono1" class="induxsoft-form-control" value="#<@('./telefono')>" maxlength="150")
                    }
                    div(class="col-sm-6")
                    {
                        small{"Email:"}
                        input(type="text" id="email" name="email" class="induxsoft-form-control" value="#<@('./email')>" maxlength="50")
                    }
                    div(class="col-sm-6")
                    {
                        small{"Notas:"}
                        input(type="text" id="notas" name="notas" class="induxsoft-form-control" value="#<@('./notas')>")
                    }
                    div(class="col-sm-6")
                    {
                        small{"Ubicación:"}
                        "input-key"(
                            name="ubicacion" 
                            id="ubicacion" 
                            "data-key"="sys_pk" 
                            "data-search"="codigo" 
                            "data-text"="descripcion" 
                            "data-source"="#<@UBICACIONES>?s=@search" 
                            "data-value"="#<to.json(@('&./ubicacion'))>" 
                            columns="codigo,descripcion" 
                            colcaptions="Código,Descripción"){$""}
                    }
                    div(class="col-sm-6")
                    {
                        small{"Usuario:"}
                        "input-key"(
                            name="uf_iuser" 
                            id="uf_iuser" 
                            "data-key"="sys_pk" 
                            "data-search"="userid" 
                            "data-text"="username" 
                            "data-source"="#<@url_dbext_service_user>?s=@search" 
                            "data-value"="#<to.json(@('&./user'))>" 
                            columns="userid,username" 
                            colcaptions="ID,Nombre"){$""}
                    }
                }
                    
                    
                    fieldset(class="form-control mt-2")
                    {
                        legend{"Domicilio"}
                        div(class="card")
                        {
                            
                            div(class="card-body")
                            {
                                div(class="mb-3 row")       
                                {
                                    div(class="col-sm-6")
                                    {
                                        small{"País"}
                                        ##
                                            do uie.dbSelect(def_pais)
                                        ##
                                    }
                                    div(class="col-sm-6")
                                    {
                                        small{"Estado"}
                                        select(class="induxsoft-form-select" id="estado"){$""}
                                    }
                                    
                                }
                                div(class="mb-3 row")       
                                {
                                    div(class="col-sm-6")
                                    {
                                        small{"Ciudad"}
                                        // input(type="text" class="form-control" name="iciudad" value="#<@('./domicilio/iciudad')>")
                                        select(class="induxsoft-form-select" id="ciudad"){$""}
                                    }
                                    div(class="col-sm-6")
                                    {
                                        small{"Colonia"}
                                        input(type="text" class="induxsoft-form-control" id="colonia" value="#<@('./domicilio/colonia')>")
                                    } 
                                }
                                div(class="mb-3")       
                                {
                                    small{"Dirección"}
                                    input(type="text" id="direccion" class="induxsoft-form-control"  value="#<@('./domicilio/direccion')>")
                                }
                                div(class="mb-3 row")       
                                {      
                                    div(class="col-sm-6")
                                    {
                                        small{"Código postal"}
                                        input(type="text" class="induxsoft-form-control" id="codpos"  value="#<@('./domicilio/codpos')>")
                                    } 
                                  div(class="col-sm-6")
                                    {
                                        small{"Teléfono"}
                                        input(type="text" class="induxsoft-form-control" id="telefono" value="#<@('./domicilio/telefonos')>")
                                    }
                                    
                        
                        
                            }                                   
                        }
                        input(type="hidden" class="form-control" id="sys_recver_Dom" name="sys_recver" value="#<@('./domicilio/sys_recver')>")
                        input(type="hidden" class="form-control" id="dom_sys_pk" name="dom_sys_pk" value="#<@('./domicilio/sys_pk')>")
                    }
                    
                    
                    
                 
                input(type="hidden" class="form-control" id="sys_recver" name="sys_recver" value="#<@('#./sys_recver')>")
                input(type="hidden" class="form-control" id="sys_pk" name="sys_pk" value="#<@('#./sys_pk')>")
            }
            div(id="status_bar" class="container-section")
            {
                $""
            }
        }

        #$
        script
        {
            $"

            var selectPais = document.getElementsByClassName('pais')[0];
            var selectEstado = document.getElementById('estado');
            var selectCiudad = document.getElementById('ciudad');

            
            $(selectPais).change( ()=>{
                $('#estado').empty();
                $('#ciudad').empty();
                listarEstados(e=>{
                    $('#estado').change();
                });
            });


            $(selectEstado).change( ()=>{
                $('#ciudad').empty();
                listarCiudades(e=>{
                    //console.log('kisya');
                });
            })
            
            function listarEstados(a)
            {
                var paisSeleccionado = $(selectPais).val();
                var urlPaisSeleccionado = '#<@url_dbext_service>edoprov/?pais='+paisSeleccionado
                $.ajax({
                        type: 'GET',
                        dataType: 'json',
                        accepts: 'application/json',
                        url: urlPaisSeleccionado,
                        
                        success: function(data) {
                            const temp3 = data;
                            $.each(temp3, function(sys_pk, nombre) {
                                $('#estado').append('<option value=' + nombre.sys_pk + '>' + nombre.nombre + '</option>');
                            });
                            a();
                        },
                        error: function(error){
                            console.log(error);
                        }        
                    });
            }

            function listarCiudades(b)
            {
                var estadoSeleccionado = $(selectEstado).val();
                var urlEstadoSeleccionado = '#<@url_dbext_service>ciudad/?edo='+estadoSeleccionado

                $.ajax({
                type: 'GET',
                 dataType: 'json',
                 accepts: 'application/json',
                 url: urlEstadoSeleccionado,
                
                    success: function(data) {
                        const temp4 = data;
                        $.each(temp4, function(sys_pk, nombre) {
                            $('#ciudad').append('<option value=' + nombre.sys_pk + '>' + nombre.nombre + '</option>');
                        });
                        b();
                    },
                    error: function(error){
                        console.log(error);
                    }
                });
            }


            
           $( document ).ready(function() {
            if('#<@('./domicilio/iciudad')>' =='')
            {
                console.log('no hay domicilio');
                $(selectPais).val('1');
                listarEstados(e=>{
                    $(selectEstado).val('7');
                    listarCiudades(e=>{
                        $(selectCiudad).val('396');
                    });
                });
            }
            else
            {
                $(selectPais).val('#<@('./estado/IPais')>');
                listarEstados(e=>{
                    $(selectEstado).val('#<@('./estado/sys_pk')>');
                    listarCiudades(e=>{
                        $(selectCiudad).val('#<@('./domicilio/iciudad')>');
                    });
                });
            }
                



            });


         

  
            "
        }
    }
    ##
    do @context.end()
}
}


                            

                            