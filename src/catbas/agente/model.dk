#include "dkli.dkh"
#!

module "agente.dk"
{
    #include "../config.dk"
    #include "../_lib/lib.dk"
    @read_query = "select sys_pk, sys_guid, sys_recver, sys_timestamp, sys_dtcreated, sys_deleted, 
    codigo,codnomina,pcomision,email,nombre,telefono,notas,domicilio1,ubicacion,uf_iuser
    from agente where #<@keyfield>=@_entity_id limit 1;"

   	agente.read::&db,&params
    {
        // if not(dbr.security.isauth(db,@CAT_AUT_AGENTE_READONLY)) { do rise_error(500,"No autorizado") }
        do dbr.apps.action.grant("CB10")

        ref agente=entity.read(db,params)
        if @@(agente,"$ubicacion")!=""{agente<"ubicacion*">:dbr.rec(db,"select * from ubicacion where sys_pk=@ubicacion",agente)}
        new d
        {
            @"domicilio1":@@(agente,"#domicilio1")
        }
        agente<"user*">:dbr.rec(db,"select sys_pk, userid,username from tuser where sys_pk=@uf_iuser",agente)
        agente<"domicilio*">:dbr.rec(db,"select codpos,colonia,direccion,notas,telefonos,sys_pk,sys_recver,iciudad from domicilio where sys_pk=@domicilio1",d)
        agente<"ciudad*">:dbr.rec(db,"select codigo,codigotel,nombre,sys_pk,sys_recver,Estado from ciudad where sys_pk=@iciudad",@@(agente,"&domicilio"))
        agente<"estado*">:dbr.rec(db,"select codigo,nombre,IPais,sys_pk,sys_recver from edoprov where sys_pk=@estado",@@(agente,"&ciudad"))
        agente<"pais*">:dbr.rec(db,"select codigo,codigotel,nombre,sys_pk,sys_recver from pais where sys_pk=@IPais",@@(agente,"&estado"))
        return  agente

        exception
        {
            do errordet(@false)
            do dbr.apps.action.log()
            do rise_error(last_error_code(),last_error())
        }
    }

    function check_autocode(&db,table,field,&data)
    {
        varvalue = dbr.vars.getd(db,"FXCA046","|0000")
        ref config = dbr.autocode.info(varvalue)
        new_code = dbr.autocode.new(db,table,field,config)

        data<"codigo">: new_code

        exception
        { }
    }

    ValidateUser::&db,&params,&data
    {
        if @@(data,"#uf_iuser") > 0
        {
            sql="SELECT COUNT(*)
            from agente a
            WHERE a.uf_iuser=@uf_iuser"

            params<"uf_iuser">:@@(data,"#uf_iuser")
            if @@(params,"#_entity_id"){sql=sql + " AND a.sys_pk<> @_entity_id"}

            users=dbr.num(db,sql,params)
            if users>0{do rise_error(500,"El usuario ya se encuentra vinculado a un agente")}
        }
    }
    agente.create::&db,&params,&data
    {
        // if not(dbr.security.isauth(db,@CAT_AUT_CREATE_AGENTE)) { do rise_error(500,"No autorizado") }
        @use_transaction = @false

		data<"sys_recver">:parse.num(@@(data,"#sys_recver"))
		data<"sys_pk">:parse.num(@@(data,"#sys_pk"))
    	
        do dbr.apps.action.pre("CB11")
        do dbr.begin(db)

        do ValidateUser(db,params,data)
        if not(isnull(@@(data,"&domicilio")))
        {
            data<"domicilio/sys_recver">:parse.num(@@(data,"#domicilio/sys_recver"))
            ref domicilio=dbr.save(db,"domicilio",@@(data,"&domicilio"))
            data<"domicilio1">:@@(domicilio,"sys_pk")
            do field.remove(data,"domicilio")
        }
        if not(isnull(@@(data,"&ciudad"))){do field.remove(data,"ciudad")}
        if not(isnull(@@(data,"&estado"))){do field.remove(data,"estado")}
        if not(isnull(@@(data,"&pais"))){do field.remove(data,"pais")}
        data<"pcomision">: @@(data, "#pcomision")

        if @@(data,"codigo")=="" { do check_autocode(db,"agente","codigo",data) }
        if field.exist(data,"ubicacion") && trim(@@(data,"$ubicacion"))==""{data<"ubicacion*">:@null}
        
        ref res = entity.create(db,params,data)
    	
        do dbr.apps.action.pos(res)
        do dbr.commit(db)
        do dbr.apps.action.ext(res)
    	
        return res

    	exception
    	{
    		if dbr.in_transaction(db) {do dbr.rollback(db)}
            do cu_error("agente")
            do dbr.apps.action.log()
    		do rise_error(last_error_code(), last_error())
    	}
    }

    agente.update::&db,&params,&data
    {
        // if not(dbr.security.isauth(db,@CAT_AUT_UPDATE_AGENTE)) { do rise_error(500,"No autorizado") }

        @use_transaction = @false

        do dbr.apps.action.pre("CB12")
        do dbr.begin(db)

        do ValidateUser(db,params,data)
        if not(isnull(@@(data,"&domicilio")))
    	{
            if not(@@(data,"domicilio/sys_recver"))
            {
                data<"domicilio/sys_recver">:parse.num(@@(data,"#domicilio/sys_recver"))
                ref domicilio=dbr.save(db,"domicilio",@@(data,"&domicilio"))
                data<"domicilio1">:@@(domicilio,"sys_pk")
            }
            do field.remove(data,"domicilio")
    	}
        if field.exist(data,"ubicacion") && trim(@@(data,"$ubicacion"))==""{data<"ubicacion*">:@null}
        if field.exist(data,"pcomision") && trim(@@(data,"$pcomision")) == "" { data<"pcomision">: 0 }
        do dbr.execute(db, "UPDATE agente SET sys_recver=0 WHERE sys_recver IS NULL AND sys_pk=@_entity_id;", params)
        do dbr.execute(db, "UPDATE agente SET sys_lock=null WHERE sys_lock=0 AND sys_pk=@_entity_id;", params)
    	
        ref res = entity.update(db,params,data)

        do dbr.apps.action.pos(res)
        do dbr.commit(db)
        do dbr.apps.action.ext(res)

        return res
        
        exception
        {
            if dbr.in_transaction(db){ do dbr.rollback(db) }
            do cu_error("agente")
            do dbr.apps.action.log()
    		do rise_error(last_error_code(), last_error())
        }
    }

    agente.delete::&db,&params
    {
        // if not(dbr.security.isauth(db,@CAT_AUT_DELETE_AGENTE)) { do rise_error(500,"No autorizado") }

        @use_transaction = @false

        do dbr.apps.action.pre("CB13")
        do dbr.begin(db)

        @keyfield="sys_pk"
        ref agente=entity.read(db,params)
        new d
        {
            @"domicilio1":@@(agente,"#domicilio1")
        }
        do dbr.delete(db,@table_name,"sys_pk=@_entity_id",params)
        do dbr.delete(db,"domicilio","sys_pk=@domicilio1",d)

        do dbr.apps.action.pos(agente)
        do dbr.commit(db)
        do dbr.apps.action.ext(agente)

        return @null

        exception
        {
            do errordet(@false)
            if dbr.in_transaction(db){ do dbr.rollback(db) }
            do dbr.apps.action.log()
            do rise_error(last_error_code(),last_error())
        }
    }

    entity.blank::&db,&params
	{
        do dbr.apps.action.grant("CB10")

		new r
		{
			@"pcomision":0
		}
		return r

        exception
        {
            do errordet(@false)
            do dbr.apps.action.log()
            do rise_error(last_error_code(),last_error())
        }
	}

    function list(&db, &params)
    {
        // if not(dbr.security.isauth(db,@CAT_AUT_ACCESS_AGENTE)) { do rise_error(500,"No autorizado") }
        do dbr.apps.action.grant("CB10")
        
        query="SELECT a.sys_pk,a.sys_guid,a.sys_dtcreated,a.sys_timestamp,
        a.sys_info,a.sys_user,a.sys_lastuser,
        a.sys_exported,a.sys_dtexported,
        a.sys_recver,a.sys_deleted,a.sys_lock,
         codigo,nombre,codnomina,telefono ,t.username usuario
            FROM agente a
            LEFT JOIN tuser t on a.uf_iuser=t.sys_pk
            WHERE IF(IFNULL(@s,'')='', true, (codigo LIKE CONCAT('%',@s,'%') OR nombre LIKE CONCAT('%',@s,'%')))
            ORDER BY codigo
            LIMIT #<@default_max_rows>;"
        return dbr.list(db, ftext(query), params)

        exception
        {
            do errordet(@false)
            do dbr.apps.action.log()
            do rise_error(last_error_code(),last_error())
        }
    }
    
    function cu_error(table)
    {
        new fields {
            @"codigo": "El código"
            @"nombre": "El nombre"
            @"codnomina": "El código de nómina"
        }
        do valide_duplicate(fields, table, last_error(), last_error_code())
    }
    function GetUsers(&db,&params)
    {
        sql = "
        SELECT
            u.sys_pk,
            u.userid,
            u.username,
            GROUP_CONCAT(DISTINCT g.groupid SEPARATOR ';') _grupos,
            GROUP_CONCAT(DISTINCT g.description SEPARATOR '; ') grupos
        FROM tuser u
            LEFT JOIN user_usergroup_ ug ON ug.users = u.sys_pk
            LEFT JOIN usergroup g ON ug.groups=g.sys_pk
        WHERE NOT IFNULL(u.sys_deleted,0)
            AND NOT IFNULL(u.external,0)
            AND IF(IFNULL(@fil_gpo,'-1')='-1', TRUE, ug.groups = @fil_gpo)
            AND IF(IFNULL(@s,'')='', TRUE, (u.userid = @s OR u.username LIKE CONCAT('%',@s,'%')))
        GROUP BY u.userid
        ORDER BY u.username ASC
        LIMIT 250;"

        return dbr.list(db,ftext(sql),params)
    }

    point @read to agente.read
    point @create to agente.create
    point @update to agente.update
    point @delete to agente.delete
    point @list to list
}