#include "dkli.dkh"
#set "meta-xml-declaration" ""
#!

module "list.dk"
{
    #include "functions.dkh"
    #include "serialize.dkh"
    #include "dbr.dkh"
    #include "dbr.vars.dkl"
    #include "uielements.dkl"
    #include "uielements.dbtable.dkl"
    #include "../_lib/icons.dk"
    #include "../_lib/scape_special_charactes.dk"

    ref db = @@(@crud_context,"&database")
    new titles
    {
        @"title": dbr.vars.getd(db,"FXCA108","")
        @"subtitle": dbr.vars.getd(db,"FXCA109","")
        @"subtitle_2": dbr.vars.getd(db,"FXCA110","")
        @"footer": dbr.vars.getd(db,"FXCA111","")
    }

    before_cell::&params,&row,&cell
    {
        /**
        * params = Parámetros de la table (def_table)
        * row = Datos (registro) de la fila
        * cell = Información de la celda
        */

        cname = @@(cell,"$column")
        ref column = @@(params,"&columns/"+cname)

        new headers
        {
            @"style": "position:sticky !important; top:0 !important; background-color:#fff;"
            @"class": "h6"
        }

        if not(field.exist(cell,"attributes")){ cell<"attributes*"> : ifnull(@@(column,"&attributes"),record.create()) }
        if @@(cell,"$element") == "th"
        {
            cell<"attributes*"> : headers
            if @@(cell,"$column") == "_actions" { headers<"class"> : "h6 text-center hide-on-print" }
        }
        
        if @@(cell,"$cell_type") != "data" && @@(cell,"$cell_type") != "unknow" { return }
        if @@(cell,"$column") == "_actions"
        {
            cell<"attributes/class"> : "hide-on-print"
            cell<"text">:ftext('
                <div class="d-flex gap-2 justify-content-center">
                    <a class="btn btn-sm btn-light btn-row-edit" id="btnEditar" href="./#<@@(row,"sys_pk")>/">Editar</a>
                    <a class="btn btn-sm btn-light" onclick="deleteEntity(#<@@(row,"sys_pk")>)" href="#" id="btnEliminar">Eliminar</a>
                </div>
            ')
        }
    }

    point bf_cell to before_cell
    
    using @table_definition
    {
        @"before_cell*": bf_cell
        @"build_array": @true
        member @"attributes"
        {
            @"class": "table table-hover"
        }
    }
    
    ref buttons = @@(@table_definition,"&buttons")

    #$
    div(class="container-lg p-0" id="view")
    {
        style
        {$'
            @media only screen and (max-width: 500px) and (min-width: 341px) {
                #view{
                    margin-top:30 !important
                }
            }

            @media print {
                tr th { background-color: #DCDCDC !important; }
                tr td { background-color: #FFF !important; color:#000 !important; }
            }
        '}

        section(id="top_area")
        {
            div(id="main_bar" class="row container-section my-2 px-0 py-2 border-bottom")
            {
                div(class="col-4 d-flex align-items-center p-0")
                {
                    h5(class="tex-no-break m-0"){$"#<ifstr(isset('@title'), @title, '')>"}
                }
                div(class="col-8 d-flex align-items-center justify-content-end p-0 gap-1")
                {
                    #!
                    if not(isnull(buttons)){that buttons(@table_definition)}
                    #$
                    a(href="./_new/" class="btn btn-sm border-secondary induxsoft-corners btn-main-action no-print" title="Agregar" id="btnAgregar"){$"Agregar"}
                    button(class="btn btn-sm border-secondary induxsoft-corners btn-main-action no-print" title="Imprimir" onclick="window.print()"){$"#<@ICON_PRINTER>"}
                    button(class="btn btn-sm border-secondary induxsoft-corners btn-main-action no-print" title="Refrescar" onclick="window.location.reload();"){$"#<@ICON_ARROW_CLOCKWISE>"}
                    a(href="/" target="_top" class="btn btn-sm border-secondary induxsoft-corners btn-main-action no-print" title="Salir" id="btn_go_back"){$"#<@ICON_X_LG>"}
                }
            }

            form(action="./" method="GET" id="form_search" class="no-print my-1 d-flex py-1")
            {
                "filter-text"(
                    "id"="ft_search"
                    "text-field"="s"
                    "placeholder"="Buscar"
                    "form"="#form_search"
                    "value"="#<@@(@@(@crud_context,'&http/request/get'),'$s')>"
                    "auto-submit"="true"
                    "class"="w-100"
                ){$""}
                input(type="hidden" id="input_search_hidden")
                input(type="hidden" id="input_search_hidden2")
            }
        }

        section(id="work_area")
        {
            div(class="show-on-print")
            {
                p(class="text-center my-0"){$"#<@@(titles,'$title')>"}
                p(class="text-center my-0"){$"#<@@(titles,'$subtitle')>"}
                p(class="text-center my-0"){$"#<@@(titles,'$subtitle_2')>"}

                div(class="row")
                {
                    div(class="col-3 text-start")
                    {
                        small(class="d-block"){ $"#<cut(@('$http/session/user/name'),25)>" }
                        small(class="d-block"){ $"#<date_str(now(),'dd/MMM/yyyy')>" }
                    }
                    div(class="col-6 text-center")
                    {
                        h4(class=""){$"Informe general de #<@title>"}
                    }
                    div(class="col-3 text-end")
                    {
                        small(class="d-block" id="lbl_filter_1"){$""}
                        small(class="d-block" id="lbl_filter_2"){$""}
                        small(class="d-block" id="lbl_filter_3"){$""}
                    }
                }
            }

            div
            {
                div(style="overflow-y:auto;max-height: 75vh;" class="mb-2" id="list_table_container")
                {
                    #! do uie.dbtable(@table_definition)
                }
                lenght = @count(@@(@table_definition,"&array_data"))
                if lenght <= 0
                {
                    message = ""
                    if @@(@crud_context,"$parameters/s") == ""
                    {
                        message = "Sin registros."
                    }
                    else 
                    {
                        message = "Sin resultados."
                    }
                    #$ div(class="text-center")
                    {
                        h6(style="background-color: #F5F5F5; padding: 10rem 0;"){"#<message>"}
                    }
                }
                #! else 
                {
                    ordby = "código"
                    if isset("order_by"){ ordby = order_by }
                    a1 = ftext("Mostrando l#<@gender>s primer#<@gender>s #<lenght> #<@title> ordenad#<@gender>s por #<ordby>.")
                    #$ small(class="text-secondary hide-on-print"){$"#<a1>"}
                }
            }
        }

        section(id="bottom_area")
        {
            //////////////////////////////////////////////////////////////////
            div(id="_custom_area")
            {
                script(src="#<@jQuery>"){$""}
                script(src="#<@js_definitive_api>"){$""}
                script(type="text/javascript")
                {$' 
                    document.addEventListener("DOMContentLoaded", () => {
                        // Script injection
                        #<@@(@crud_context,"script")>
                    });
                '}
            }
        }
    }
}